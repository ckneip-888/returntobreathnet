---
export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  lang: 'en' | 'de';
  pinned?: boolean;
}

const { href, title, description, pubDate, tags, lang, pinned = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', {
  day: '2-digit',
  month: '2-digit',
  year: '2-digit',
});

const readLabel = lang === 'de' ? 'READ' : 'READ';
const pinnedLabel = lang === 'de' ? 'angeheftet' : 'pinned';
---

<article class="article-card py-7 group">
  <a href={href} class="block">
    <div class="flex items-baseline gap-4 mb-3 flex-wrap">
      {pinned && (
        <span class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-[0.28em] text-sapphire-400">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-bottom: -1px;">
            <path d="M12 17v5"/>
            <path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
          </svg>
          {pinnedLabel}
        </span>
      )}
      <time datetime={pubDate.toISOString()} class="micro-label">{formattedDate}</time>
      {tags.length > 0 && <span class="micro-label">{tags.slice(0, 2).join(' · ').toUpperCase()}</span>}
    </div>
    <h3 class="text-2xl font-light text-slate-100 group-hover:text-white tracking-tight leading-snug mb-3 transition-colors">
      {title}
    </h3>
    <p class="text-[15px] text-slate-400 leading-relaxed font-light max-w-2xl" set:html={description}></p>
    <div class="mt-4 micro-label-accent inline-flex items-center gap-1.5 group-hover:gap-3 transition-all">
      {readLabel}
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </div>
  </a>
</article>
