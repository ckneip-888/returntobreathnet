---
export interface Props {
  lang: 'en' | 'de';
}

const { lang } = Astro.props;

const labels = {
  en: {
    site: 'SITE',
    elsewhere: 'ELSEWHERE',
    contact: 'CONTACT',
    about: 'About',
    writing: 'Writing',
    impressum: 'Impressum',
    youtube: 'YouTube',
    appStore: 'App Store',
    googlePlay: 'Google Play',
    seal: 'SOVEREIGN SEAL · 2026',
    version: 'v0.1 · PROTOTYPE',
    copyright: '© 2026 Christoph Kneip. All writing on this site is original work.',
  },
  de: {
    site: 'SEITE',
    elsewhere: 'ANDERSWO',
    contact: 'KONTAKT',
    about: 'Über',
    writing: 'Schreiben',
    impressum: 'Impressum',
    youtube: 'YouTube',
    appStore: 'App Store',
    googlePlay: 'Google Play',
    seal: 'SOVEREIGN SEAL · 2026',
    version: 'v0.1 · PROTOTYP',
    copyright: '© 2026 Christoph Kneip. Alle Texte sind Originalwerk.',
  },
};

const t = labels[lang];

// EN paths from root, DE paths from /de/ (only home exists for now)
const basePath = lang === 'de' ? '/de' : '';
---

<footer class="bg-slate-950 pt-16 pb-10">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-4">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <polygon points="10,2 17,6 17,14 10,18 3,14 3,6" stroke="#0F52BA" stroke-width="1" fill="none" />
            <circle cx="10" cy="10" r="2.2" fill="#0F52BA" />
          </svg>
          <span class="text-[12px] font-medium tracking-[0.2em] text-slate-100">RETURNTOBREATH.NET</span>
        </div>
        <p class="text-[14px] text-slate-500 leading-relaxed font-light max-w-md">
          The <span class="text-slate-300 font-medium">Return App</span> is a quiet breathing utility for nervous system regulation. A practical tool for using your breath to access clarity, calm, and coherence — no matter what is happening inside or around you.
        </p>
      </div>

      <div class="md:col-span-2">
        <div class="micro-label-accent mb-4">{t.site}</div>
        <ul class="space-y-2.5 text-[13px] text-slate-400 font-light">
          <li><a href={`${basePath}/about/`} class="hover:text-slate-100 transition-colors">{t.about}</a></li>
          <li><a href={`${basePath}/writing/`} class="hover:text-slate-100 transition-colors">{t.writing}</a></li>
          <li><a href={`${basePath}/impressum/`} class="hover:text-slate-100 transition-colors">{t.impressum}</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <div class="micro-label-accent mb-4">{t.elsewhere}</div>
        <ul class="space-y-2.5 text-[13px] text-slate-400 font-light">
          <li>
            <a href="https://www.youtube.com/@returnpulse" target="_blank" rel="noopener" class="hover:text-slate-100 inline-flex items-center gap-1.5 transition-colors">
              {t.youtube} <i data-lucide="external-link" class="w-3 h-3"></i>
            </a>
          </li>
          <li>
            <a href="#" aria-disabled="true" class="hover:text-slate-100 inline-flex items-center gap-1.5 transition-colors">
              {t.appStore} <i data-lucide="external-link" class="w-3 h-3"></i>
            </a>
          </li>
          <li>
            <a href="#" aria-disabled="true" class="hover:text-slate-100 inline-flex items-center gap-1.5 transition-colors">
              {t.googlePlay} <i data-lucide="external-link" class="w-3 h-3"></i>
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <div class="micro-label-accent mb-4">{t.contact}</div>
        <ul class="space-y-2.5 text-[13px] text-slate-400 font-light">
          <li><a href="mailto:info@returnapp.org" class="hover:text-slate-100 transition-colors">info@returnapp.org</a></li>
          <li class="text-slate-600">Zürich, Switzerland</li>
        </ul>
      </div>
    </div>

    <div class="hairline mb-8"></div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <div class="seal text-slate-400">{t.seal}</div>
        <span class="text-slate-800">·</span>
        <div class="text-[11px] text-slate-600 font-mono">{t.version}</div>
      </div>
      <div class="text-[11px] text-slate-600 font-light">{t.copyright}</div>
    </div>
  </div>
</footer>
