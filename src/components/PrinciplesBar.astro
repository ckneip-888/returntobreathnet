---
export interface Props {
  lang: 'en' | 'de';
}

const { lang } = Astro.props;

const items = {
  en: [
    { icon: 'circle-slash', label: 'NO STREAKS', text: 'Tools should not gamify your nervous system.' },
    { icon: 'trending-up', label: 'NO OPTIMIZATION', text: 'You are already enough. The work is to return.' },
    { icon: 'hourglass', label: 'USED, NOT LIVED IN', text: 'Open. Breathe. Close. The opposite of attention capture.' },
  ],
  de: [
    { icon: 'circle-slash', label: 'KEINE STREAKS', text: 'Werkzeuge sollten dein Nervensystem nicht gamifizieren.' },
    { icon: 'trending-up', label: 'KEINE OPTIMIERUNG', text: 'Du bist bereits genug. Die Arbeit ist zurückzukehren.' },
    { icon: 'hourglass', label: 'BENUTZT, NICHT BEWOHNT', text: 'Öffnen. Atmen. Schließen. Das Gegenteil von Aufmerksamkeitsfang.' },
  ],
};

const t = items[lang];
---

<section class="border-t border-b border-slate-900 bg-slate-950/50">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-y-8 gap-x-10">
      {t.map((item) => (
        <div>
          <div class="flex items-center justify-center w-10 h-10 rounded-md border border-sapphire-800/50 mb-4">
            <i data-lucide={item.icon} class="w-4 h-4 text-sapphire-400"></i>
          </div>
          <div class="micro-label-accent mb-2">{item.label}</div>
          <p class="text-[13px] text-slate-400 leading-relaxed font-light">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
