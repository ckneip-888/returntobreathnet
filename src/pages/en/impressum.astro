---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'en/impressum');
if (!entry) throw new Error('impressum page content missing');
const { Content } = await render(entry);
---

<BaseLayout
  title="Impressum — Return to Breath"
  description="Legal information, contact details, and disclaimers for returntobreath.net."
  lang="en"
>
  <article class="max-w-3xl mx-auto px-6 lg:px-8 pt-32 pb-24">
    <div
      class="prose prose-slate max-w-none
             prose-headings:font-light prose-headings:tracking-tight
             prose-h1:text-4xl prose-h1:mb-10
             prose-h2:text-xl prose-h2:mt-12 prose-h2:mb-4
             prose-p:font-light prose-p:leading-relaxed prose-p:text-slate-300
             prose-a:text-sapphire-400 prose-a:no-underline hover:prose-a:text-sapphire-300
             prose-strong:text-slate-100 prose-strong:font-medium
             prose-hr:border-slate-800 prose-hr:my-10
             prose-em:text-slate-400"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
