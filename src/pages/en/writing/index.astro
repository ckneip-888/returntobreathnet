---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Writing — Return to Breath"
  description="All foundational essays on breath, coherence, nervous system regulation, and the practice of return. By Christoph Kneip."
  lang="en"
>
  <section class="max-w-3xl mx-auto px-6 lg:px-8 pt-32 pb-24">
    <header class="mb-12">
      <div class="micro-label-accent mb-4">FIELD NOTES · ARCHIVE</div>
      <h1 class="text-4xl sm:text-5xl font-light tracking-tight text-slate-50 leading-tight mb-4">
        Writing.
      </h1>
      <p class="text-lg text-slate-400 leading-relaxed font-light max-w-2xl">
        Foundational essays on breath, coherence, and the practice of return. Updated weekly.
      </p>
    </header>

    <div class="space-y-0">
      {posts.map((post) => (
        <ArticleCard
          href={`/en/writing/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          lang="en"
        />
      ))}
    </div>
  </section>
</BaseLayout>
