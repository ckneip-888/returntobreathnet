---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SapphirePulse from '../components/SapphirePulse.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import PrinciplesBar from '../components/PrinciplesBar.astro';
import ArticleCard from '../components/ArticleCard.astro';

// Pull EN blog posts, pinned first, then newest first
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
const posts = allPosts.sort((a, b) => {
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const homeJsonLd = [
  {
    '@type': 'MedicalWebPage',
    '@id': 'https://returntobreath.net/#medical-webpage',
    name: 'Nervous System Regulation Through Conscious Breath',
    url: 'https://returntobreath.net/',
    description: 'Practical breath protocols for nervous system regulation, cognitive load, future anxiety, and identity transition.',
    about: [
      { '@type': 'MedicalCondition', name: 'Chronic Stress' },
      { '@type': 'MedicalCondition', name: 'Anxiety' },
      { '@type': 'MedicalCondition', name: 'Burnout' },
      { '@type': 'MedicalCondition', name: 'Sleep Disturbance' },
    ],
    audience: {
      '@type': 'PeopleAudience',
      audienceType: 'Knowledge workers, parents, professionals in identity transition, people experiencing future anxiety',
    },
  },
];
---

<BaseLayout
  title="Return to Breath — The Return App, a quiet breathing utility"
  description="The Return App is a quiet breathing utility for nervous system regulation. Built for those under acute cognitive load, in difficult life phases, or with future anxiety."
  lang="en"
  jsonLd={homeJsonLd}
>
  <!-- ╔═══ HERO (reduced ~1/3) ═══╗ -->
  <section class="atmosphere relative pt-20 pb-12 lg:pt-28 lg:pb-16 overflow-hidden">
    <div class="absolute inset-0 hex-bg opacity-30 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-6 text-center z-10">
      <div class="flex justify-center mb-6">
        <SapphirePulse size="lg" />
      </div>

      <div class="micro-label-accent mb-4">INTRODUCING · THE RETURN APP</div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-light tracking-tight text-slate-50 leading-[1.05] mb-5">
        Return to Breath.
      </h1>

      <p class="text-[15px] text-slate-400 max-w-2xl mx-auto leading-relaxed mb-8 font-light">
        The <span class="text-slate-200 font-medium">Return App</span> is a quiet breathing utility for nervous system regulation. Built for those under acute cognitive load, in difficult life phases, or with future anxiety. No streaks. No endless optimization. Open the app. Breathe for five minutes. Ground your day.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        <a href="#" aria-disabled="true" class="btn-primary inline-flex items-center justify-center gap-2.5 px-6 py-3 rounded-md text-[14px] font-medium text-white tracking-wide transition-all">
          <i data-lucide="apple" class="w-4 h-4"></i>
          <span>Download on the App Store</span>
        </a>
        <a href="#" aria-disabled="true" class="inline-flex items-center justify-center gap-2.5 px-6 py-3 rounded-md text-[14px] font-medium text-slate-100 tracking-wide border border-slate-700 bg-slate-900/40 hover:bg-slate-900/80 hover:border-slate-600 transition-all">
          <i data-lucide="play" class="w-4 h-4"></i>
          <span>Get it on Google Play</span>
        </a>
      </div>

      <div class="micro-label">THE RETURN APP · iOS · ANDROID · 2026</div>
    </div>
  </section>

  <div class="hairline max-w-[1440px] mx-auto"></div>

  <!-- ╔═══ 3-COLUMN ═══╗ -->
  <section class="max-w-[1440px] mx-auto px-6 lg:px-12 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_11fr_4fr] gap-10 lg:gap-12">

      <!-- LEFT · ANCHOR -->
      <aside class="space-y-10 lg:order-1 order-2">
        <div>
          <div class="micro-label-accent mb-4">01 · THE EXPLAINER</div>
          <a href="https://www.youtube.com/@returnpulse" target="_blank" rel="noopener noreferrer" class="block hex-border rounded-md overflow-hidden group transition-all">
            <div class="relative aspect-video bg-gradient-to-br from-slate-900 via-slate-950 to-sapphire-900/40 flex items-center justify-center overflow-hidden">
              <svg class="absolute inset-0 w-full h-full opacity-40" viewBox="0 0 200 113" aria-hidden="true">
                <g class="rotate-slow" style="transform-origin: 100px 56px;">
                  <polygon points="100,10 160,42 160,70 100,102 40,70 40,42" fill="none" stroke="#0F52BA" stroke-width="0.5" />
                  <polygon points="100,30 140,50 140,62 100,82 60,62 60,50" fill="none" stroke="#0F52BA" stroke-width="0.5" />
                </g>
                <circle cx="100" cy="56" r="14" fill="#0F52BA" fill-opacity="0.6" />
                <circle cx="100" cy="56" r="6" fill="#1e6fd9" />
              </svg>
              <div class="relative z-10 w-12 h-12 rounded-full bg-sapphire/90 backdrop-blur flex items-center justify-center shadow-lg group-hover:scale-105 transition-transform">
                <i data-lucide="play" class="w-5 h-5 text-white" style="margin-left: 2px;"></i>
              </div>
            </div>
            <div class="p-4 border-t border-sapphire-900/30">
              <div class="text-[13px] font-medium text-slate-100 group-hover:text-white transition-colors">How Return works in 90 seconds</div>
              <div class="micro-label mt-2 flex items-center gap-1.5">
                <i data-lucide="youtube" class="w-3 h-3"></i>
                <span>#RETURNPULSE</span>
              </div>
            </div>
          </a>
        </div>

        <NewsletterForm lang="en" />

        <div class="hex-border rounded-md p-5 space-y-3">
          <div class="micro-label-accent">03 · THE RETURN APP</div>
          <p class="text-[14px] text-slate-300 leading-relaxed">
            Return is a quiet breathing utility. Open it. Breathe. Close it. The opposite of an attention economy.
          </p>
          <div class="flex flex-col gap-2 pt-1">
            <a href="#" aria-disabled="true" class="text-[13px] text-sapphire-400 hover:text-sapphire-300 inline-flex items-center gap-1.5 transition-colors">
              <i data-lucide="apple" class="w-3.5 h-3.5"></i> App Store →
            </a>
            <a href="#" aria-disabled="true" class="text-[13px] text-sapphire-400 hover:text-sapphire-300 inline-flex items-center gap-1.5 transition-colors">
              <i data-lucide="play" class="w-3.5 h-3.5"></i> Google Play →
            </a>
          </div>
        </div>
      </aside>

      <!-- CENTER · STREAM -->
      <main class="lg:order-2 order-1" id="writing">
        <header class="mb-10">
          <div class="micro-label-accent mb-4">FIELD NOTES · WRITING</div>
          <h2 class="text-3xl lg:text-4xl font-light tracking-tight text-slate-50 leading-tight mb-3">
            On breath, coherence, and the practice of return.
          </h2>
          <p class="text-[15px] text-slate-400 leading-relaxed max-w-xl font-light">
            Here is how we think. Here is what we believe. Here is what is possible. Weekly essays.
          </p>
        </header>

        <div class="space-y-0">
          {posts.map((post) => (
            <ArticleCard
              href={`/writing/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              lang="en"
              pinned={post.data.pinned}
            />
          ))}
        </div>

        <div class="mt-12 flex items-center justify-between pt-6 border-t border-slate-900">
          <span class="micro-label">{posts.length} OF {posts.length} · LAUNCH ARCHIVE</span>
          <a href="/writing/" class="text-[13px] text-sapphire-400 hover:text-sapphire-300 inline-flex items-center gap-1.5 transition-colors">
            View archive <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
          </a>
        </div>
      </main>

      <!-- RIGHT · MATRIX -->
      <aside class="lg:order-3 order-3 space-y-6">
        <div>
          <div class="micro-label-accent mb-4">THE RETURN MATRIX</div>
          <p class="text-[13px] text-slate-500 leading-relaxed font-light mb-6">
            Outcomes, in the language you already use.
          </p>
        </div>

        <article class="hex-border rounded-md p-5">
          <div class="micro-label-accent mb-3">FOR KNOWLEDGE WORKERS</div>
          <p class="text-[14px] text-slate-200 leading-relaxed font-light">Isolate your system from cognitive noise in 5.5 seconds.</p>
        </article>

        <article class="hex-border rounded-md p-5">
          <div class="micro-label-accent mb-3">FOR PARENTS</div>
          <p class="text-[14px] text-slate-200 leading-relaxed font-light">Regulate your own nervous system before co-regulating theirs.</p>
        </article>

        <article class="hex-border rounded-md p-5">
          <div class="micro-label-accent mb-3">POST-IDENTITY EVOLUTION</div>
          <p class="text-[14px] text-slate-200 leading-relaxed font-light">Who are you when you are not what you do? Access the Still Point.</p>
        </article>

        <article class="hex-border rounded-md p-5">
          <div class="micro-label-accent mb-3">FOR FUTURE ANXIETY</div>
          <p class="text-[14px] text-slate-200 leading-relaxed font-light">When AI, geopolitics, and uncertainty spike your blood chemistry — interrupt the loop.</p>
        </article>

        <article class="hex-border rounded-md p-5">
          <div class="micro-label-accent mb-3">FOR THE WELLNESS-BURNED</div>
          <p class="text-[14px] text-slate-200 leading-relaxed font-light">No streaks. No infinite optimization. A quiet tool that works.</p>
        </article>

        <div class="pt-4 mt-2 border-t border-slate-900">
          <div class="micro-label-accent mb-4">DEFINITIONS</div>
          <dl class="space-y-4 text-[12.5px] leading-relaxed">
            <div>
              <dt class="text-slate-200 font-medium mb-0.5">The Breathline</dt>
              <dd class="text-slate-500 font-light">The exact physiological threshold where the nervous system transitions from noise into coherence.</dd>
            </div>
            <div>
              <dt class="text-slate-200 font-medium mb-0.5">Coherence</dt>
              <dd class="text-slate-500 font-light">The state where heart rhythm, breath, and nervous system synchronize. Measurable via heart rate variability.</dd>
            </div>
            <div>
              <dt class="text-slate-200 font-medium mb-0.5">Sympathetic Autopilot</dt>
              <dd class="text-slate-500 font-light">Chronic activation of the fight-or-flight system. The default state of most overstimulated adults.</dd>
            </div>
            <div>
              <dt class="text-slate-200 font-medium mb-0.5">Post-Identity</dt>
              <dd class="text-slate-500 font-light">The condition of existing without the structures of role or output that previously defined the self.</dd>
            </div>
          </dl>
        </div>
      </aside>

    </div>
  </section>

  <PrinciplesBar lang="en" />
</BaseLayout>
